{
  "manifest_version": 3,
  "name": "Recap for Meet",
  "version": "0.1.1",
  "description": "Captures Google Meet live captions and sends them to the Recap Mac app.",
  "key": "",
  "permissions": ["storage", "sidePanel", "nativeMessaging"],
  "host_permissions": ["https://meet.google.com/*", "http://127.0.0.1/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Recap"
  },
  "options_page": "options.html"
}
